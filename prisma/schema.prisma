generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Job {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  title       String
  company     String
  location    String
  type        String   // Full-time, Part-time, Contract, Remote
  category    String   // Engineering, Design, Marketing, etc.
  role        String?  // Engineering, Product, Design, Marketing/Growth, Business Development, Operations/HR, Community/Support
  description String?  // Full job description (formatted/cleaned)
  raw_description String? // Original unformatted description (for toggle feature)
  url         String   @unique
  salary      String?
  tags        String?  // JSON string array
  source      String   // web3.career, wellfound, etc.
  region      String   // Global or Korea
  postedDate  DateTime?
  crawledAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive      Boolean   @default(true)
  lastValidated DateTime?

  // Enhanced job details (crawled from detail pages)
  requirements     String?  // Required qualifications (HTML/Markdown)
  responsibilities String?  // Job responsibilities (HTML/Markdown)
  benefits         String?  // Benefits and perks (HTML/Markdown)
  salaryMin        Int?     // Minimum salary (annual, USD)
  salaryMax        Int?     // Maximum salary (annual, USD)
  salaryCurrency   String?  // Currency code (USD, KRW, etc.)
  deadline         DateTime? // Application deadline
  experienceLevel  String?  // Junior, Mid, Senior, Lead
  remoteType       String?  // Remote, Hybrid, Onsite
  companyLogo      String?  // Company logo URL
  companyWebsite   String?  // Company website URL

  // Enrichment fields (from priority-companies registry)
  backers         String[]  // VC backers
  badges          String[]  // Computed badges (Verified, Web3 Perks, etc.)
  sector          String?   // Company sector (DeFi, Layer 1, etc.)
  office_location String?   // Company office location
  is_featured     Boolean   @default(false)
  is_urgent       Boolean   @default(false)

  // User-posted job fields
  postedBy      String?  // Wallet address of poster
  reportCount   Int      @default(0)
  isHidden      Boolean  @default(false)

  // Relations
  reports       JobReport[]

  @@index([company])
  @@index([source])
  @@index([region])
  @@index([isActive])
  @@index([postedDate])
  @@index([postedBy])
  @@index([experienceLevel])
  @@index([role])
}

model JobReport {
  id             String   @id @default(dbgenerated("gen_random_uuid()"))
  jobId          String
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reporterWallet String?
  reporterIp     String?
  reason         String
  createdAt      DateTime @default(now())

  @@index([jobId])
  @@index([reporterWallet])
  @@index([createdAt])
}

model WalletBlacklist {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  wallet      String   @unique
  reason      String?
  createdAt   DateTime @default(now())

  @@index([wallet])
}

model CrawlLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  source    String
  status    String   // success, failed
  jobCount  Int      @default(0)
  error     String?
  createdAt DateTime @default(now())

  @@index([source])
  @@index([createdAt])
}
